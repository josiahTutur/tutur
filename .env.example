# Supabase — copy this file to .env.local and fill in your project's values.
# Both are browser-safe (the anon key is protected by Row-Level Security).
# Find them in Supabase: Project Settings → API.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
